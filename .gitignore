.claude/worktrees/
# Locally-linked teach-me skill (dev convenience; the source lives in skills/)
.claude/skills/teach-me

# --- Secrets / local environment (never commit) ---
.env
.env.*
!.env.example
!evals/.env.example

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/

# --- Virtual environments (uv / venv / pipenv) ---
