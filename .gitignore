.venv/
venv/
env/

# --- Node (defensive) ---
node_modules/

# --- OS / editor cruft ---
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp

# --- Git worktrees (general) ---
.worktrees/

# --- Superpowers SDD process artifacts ---
.superpowers/

